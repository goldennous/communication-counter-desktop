{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Т-Счётчик",
  "version": "0.1.0",
  "identifier": "com.sozynov.t-counter",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev:docker",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Т-Счётчик",
        "width": 900,
        "height": 700,
        "minWidth": 200,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {}
  }
}
